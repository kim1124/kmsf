{
  "name": "@kmsf/charts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.example.config.ts",
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "env -u NO_COLOR playwright test --config=playwright.config.ts",
    "verify": "npm run lint && npm run test:run && npm run build",
    "verify:full": "npm run verify && npm run verify:e2e",
    "verify:e2e": "npm run test:e2e"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "dayjs": "latest",
    "echarts": "5.6.0",
    "echarts-wordcloud": "latest"
  },
  "devDependencies": {
    "@kmsf/gridstack": "^1.0.0",
    "@playwright/test": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.6.0",
    "typescript": "^6.0.3",
    "vite": "latest",
    "vitest": "latest"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <20.0.0",
    "react-dom": ">=18.0.0 <20.0.0"
  }
}
