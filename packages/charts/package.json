{
  "name": "@kmsf/charts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.example.config.ts",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "verify": "npm run lint && npm run test:run && npm run build",
    "verify:full": "npm run lint && npm run test:run && npm run build && npm run test:e2e"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "dayjs": "latest",
    "echarts": "latest",
    "echarts-wordcloud": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <20.0.0",
    "react-dom": ">=18.0.0 <20.0.0"
  }
}
