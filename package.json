{
  "name": "kmsf-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "examples/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/patch-next-postcss-metadata.mjs",
    "dev": "npm --workspace=apps/kmsf run dev --",
    "build": "npm --workspace=apps/kmsf run build",
    "start": "npm --workspace=apps/kmsf run start --",
    "lint": "npm --workspace=apps/kmsf run lint",
    "test": "npm --workspace=apps/kmsf run test",
    "test:run": "npm --workspace=apps/kmsf run test:run",
    "test:e2e": "npm --workspace=apps/kmsf run test:e2e --",
    "test:e2e:headed": "npm --workspace=apps/kmsf run test:e2e:headed --",
    "verify": "npm --workspace=apps/kmsf run verify",
    "smoke:pack:charts": "npm_config_cache=/private/tmp/kmsf-npm-cache npm pack --workspace=@kmsf/charts --dry-run",
    "smoke:pack:gridstack": "npm_config_cache=/private/tmp/kmsf-npm-cache npm pack --workspace=@kmsf/gridstack --dry-run",
    "smoke:pack:data-table": "npm_config_cache=/private/tmp/kmsf-npm-cache npm pack --workspace=@kmsf/data-table --dry-run",
    "smoke:pack:create-kmsf": "npm_config_cache=/private/tmp/kmsf-npm-cache npm pack --workspace=create-kmsf --dry-run",
    "verify:full": "npm --workspace=apps/kmsf run verify:full",
    "verify:packages": "npm --workspace=@kmsf/charts run verify && npm --workspace=@kmsf/gridstack run verify && npm --workspace=@kmsf/data-table run verify && npm --workspace=create-kmsf run verify && npm --workspace=@kmsf/generator-core run verify",
    "verify:all": "npm run verify && npm run verify:packages",
    "changeset": "changeset",
    "version:packages": "changeset version"
  },
  "overrides": {
    "postcss": "8.5.14"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0"
  }
}
